# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=quantmodel
POSTGRES_PASSWORD=quantmodel_secret
POSTGRES_DB=quantmodel
DATABASE_URL=postgresql+asyncpg://quantmodel:quantmodel_secret@localhost:5432/quantmodel

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MetaTrader 5 ───────────────────────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── News / Scraping ────────────────────────────────────────────────────────────
FOREXFACTORY_BASE_URL=https://www.forexfactory.com
SCRAPE_INTERVAL_SECONDS=300

# ── Trading defaults ───────────────────────────────────────────────────────────
DEFAULT_RISK_PCT=1.0
DEFAULT_MAX_POSITIONS=5
DEFAULT_DAILY_LOSS_LIMIT=3.0
DEFAULT_TRADING_MODE=scalp
